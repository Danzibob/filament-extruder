{
  "configurations": [
    {
      "name": "Arduino",
      "includePath": [
        "${workspaceFolder}",
        "${env:HOME}/.arduino15/internal/**"
      ],
      "defines": [
        "__AVR_ATmega328P__",
        "F_CPU=16000000L",
        "ARDUINO=10819"
      ],
      "compilerPath": "${env:HOME}/.arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino7/bin/avr-g++",
      "cStandard": "gnu11",
      "cppStandard": "gnu++17",
      "intelliSenseMode": "gcc-x64"
    }
  ],
  "version": 4
}
